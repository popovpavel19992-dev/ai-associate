# =============================================================================
# ClearTerms / AI Associate — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# All variables without defaults are REQUIRED.
# =============================================================================

# --- Database (Neon Postgres) ------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Supabase (Storage / RLS) -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Clerk (Authentication) --------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# --- AWS (S3 Document Storage + KMS Encryption) ------------------------------
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_KMS_KEY_ID=your-kms-key-id

# --- Anthropic (Claude AI) --------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Cloud Vision (OCR) -----------------------------------------------
GOOGLE_CLOUD_VISION_KEY=your-google-cloud-vision-key

# --- Stripe (Payments & Subscriptions) ---------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (Transactional Email) --------------------------------------------
RESEND_API_KEY=re_...

# --- Inngest (Background Jobs) — optional in dev ----------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Observability (optional) ------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- CourtListener (Case Law Research) ---------------------------------------
COURTLISTENER_API_TOKEN=your_courtlistener_api_token_here

# GovInfo (GPO) API key for U.S. Code lookup/search via api.govinfo.gov.
# Free api.data.gov key; sign up at https://api.data.gov/signup/ (36000 req/hr).
GOVINFO_API_KEY=

# --- Resend Inbound Webhooks -------------------------------------------------
RESEND_INBOUND_WEBHOOK_SECRET=
REPLY_DOMAIN=reply.clearterms.ai

# --- Resend Events Webhook (open/click/delivered/complained tracking) --------
RESEND_EVENTS_WEBHOOK_SECRET=

# --- Web Push (PWA Notifications) -------------------------------------------
# Generate a fresh keypair with: npx web-push generate-vapid-keys
# Both keys are required to enable push notifications. VAPID_SUBJECT must be
# either a mailto: URL or an https URL identifying the application contact.
# When unset, the push pipeline is a no-op (subscribe still records, but no
# notifications are dispatched).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@clearterms.ai
# Public key exposed to the browser for pushManager.subscribe — must match
# VAPID_PUBLIC_KEY exactly.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- ConvertAPI (DOCX -> PDF for filing-package exhibits) --------------------
# Optional. When unset, DOCX exhibits are rejected with a "convert to PDF first"
# message. When set, DOCX exhibits are converted via ConvertAPI managed service.
# Sign up at https://www.convertapi.com/ (100 free conversions/month).
CONVERTAPI_SECRET=

# AI Case Strategy Assistant (Phase 4 #2)
VOYAGE_API_KEY=
STRATEGY_BETA_ORG_IDS=
STRATEGY_MODEL=claude-sonnet-4-6
STRATEGY_TOP_K_CHUNKS=12
